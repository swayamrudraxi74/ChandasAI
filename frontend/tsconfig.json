{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  
  "compilerOptions": {
    "module": "esnext", 
    "moduleResolution": "bundler", 
  
    "noEmit": true,
    "jsx": "react-jsx", 
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vite/client"],
    
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}